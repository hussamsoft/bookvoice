# Backend Configuration
# Comma-separated list of allowed CORS origins (JSON array).
# For the standalone desktop app (same-origin) this can be left as ["*"].
# For frontend dev servers, add e.g. "http://localhost:5173", "http://localhost:4173".
CORS_ORIGINS=["*"]

# Optional: use GPU for OCR (default is CPU to save VRAM for TTS)
OCR_USE_GPU=false
